# ============================================================================
# workXperts Anreicherungs-App — Beispiel-Umgebungsvariablen
# ----------------------------------------------------------------------------
# WICHTIG:
#  - Diese Datei NUR als Vorlage. Echte Werte NIEMALS committen.
#  - FRONTEND-Variablen (VITE_*) sind im Browser sichtbar -> hier stehen NUR
#    der öffentliche Supabase-Anon-Key und die Projekt-URL (beide sind public).
#  - ALLE GEHEIMNISSE (Shopify-Token, Firecrawl-Key) gehören ausschließlich in
#    die SUPABASE EDGE FUNCTION SECRETS — siehe unten, NICHT hierher ins Frontend.
# ============================================================================

# --- Frontend (öffentlich, im Browser sichtbar — KEIN Geheimnis) ------------
VITE_SUPABASE_URL=https://<dein-projekt-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...  # öffentlicher anon-Key aus Supabase > Settings > API

# ============================================================================
# Die folgenden Werte NICHT hier setzen, sondern in Supabase als Edge-Function-
# Secrets hinterlegen (Dashboard > Project Settings > Edge Functions > Secrets,
# oder: supabase secrets set KEY=VALUE). Hier nur zur Dokumentation gelistet.
# ============================================================================
#
# SHOPIFY_ADMIN_HOST=workxperts.myshopify.com        # Backend-Domain, NICHT die Custom-Domain
# SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxx  # Custom-App-Token
# SHOPIFY_API_VERSION=2025-07
# FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Scopes der Shopify-Custom-App:
#   read_products, write_products, read_inventory, read_orders
#
# Optional (nur Team/Enterprise — NICHT eingebaut, nur vorgesehen):
# ANTHROPIC_ADMIN_KEY=sk-ant-admin-xxxxxxxxxxxxxxxxx
